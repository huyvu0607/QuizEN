<?xml version="1.0" encoding="utf-8"?>
<navigation xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/nav_graph"
    app:startDestination="@id/homeFragment">

    <fragment
        android:id="@+id/homeFragment"
        android:name="com.lumina.app.ui.home.HomeFragment"
        android:label="Home"
        tools:layout="@layout/fragment_home" />

    <fragment
        android:id="@+id/coursesFragment"
        android:name="com.lumina.app.ui.course.CoursesFragment"
        android:label="Courses"
        tools:layout="@layout/fragment_placeholder" />

    <fragment
        android:id="@+id/practiceFragment"
        android:name="com.lumina.app.ui.practice.PracticeFragment"
        android:label="Practice"
        tools:layout="@layout/fragment_placeholder" />

    <fragment
        android:id="@+id/statsFragment"
        android:name="com.lumina.app.ui.stats.StatsFragment"
        android:label="Stats"
        tools:layout="@layout/fragment_placeholder" />

    <fragment
        android:id="@+id/profileFragment"
        android:name="com.lumina.app.ui.profile.ProfileFragment"
        android:label="Profile"
        tools:layout="@layout/fragment_placeholder" />

    <fragment
        android:id="@+id/courseDetailFragment"
        android:name="com.lumina.app.ui.course.CourseDetailFragment"
        android:label="Course Detail"
        tools:layout="@layout/fragment_course_detail" />

    <fragment
        android:id="@+id/addUnitFragment"
        android:name="com.lumina.app.ui.unit.AddUnitFragment"
        android:label="Add Unit"
        tools:layout="@layout/fragment_add_unit" />

    <fragment
        android:id="@+id/unitDetailFragment"
        android:name="com.lumina.app.ui.unit.UnitDetailFragment"
        android:label="Unit Detail"
        tools:layout="@layout/fragment_unit_detail" />

    <fragment
        android:id="@+id/addLessonFragment"
        android:name="com.lumina.app.ui.lesson.AddLessonFragment"
        android:label="Add Lesson"
        tools:layout="@layout/fragment_add_lesson" />

    <fragment
        android:id="@+id/vocabularyListFragment"
        android:name="com.lumina.app.ui.vocabulary.VocabularyListFragment"
        android:label="Vocabulary List"
        tools:layout="@layout/fragment_vocabulary_list" />

    <fragment
        android:id="@+id/addVocabularyFragment"
        android:name="com.lumina.app.ui.vocabulary.AddVocabularyFragment"
        android:label="Add Vocabulary"
        tools:layout="@layout/fragment_add_vocabulary">
        <argument
            android:name="lesson_id"
            app:argType="long" />
        <argument
            android:name="vocabulary_id"
            android:defaultValue="-1L"
            app:argType="long" />
    </fragment>

    <fragment
        android:id="@+id/importVocabularyFragment"
        android:name="com.lumina.app.ui.vocabulary.ImportVocabularyFragment"
        android:label="Import Vocabulary"
        tools:layout="@layout/fragment_import_vocabulary">
        <argument
            android:name="lesson_id"
            app:argType="long" />
    </fragment>

    <fragment
        android:id="@+id/flashcardFragment"
        android:name="com.lumina.app.ui.flashcard.FlashcardFragment"
        android:label="Flashcard"
        tools:layout="@layout/fragment_flashcard">
        <argument
            android:name="lesson_id"
            android:defaultValue="-1L"
            app:argType="long" />
        <argument
            android:name="topic_group_id"
            android:defaultValue="-1L"
            app:argType="long" />
        <argument
            android:name="lesson_name"
            app:argType="string"
            android:defaultValue="Flashcard" />
    </fragment>

    <fragment
        android:id="@+id/topicGroupFragment"
        android:name="com.lumina.app.ui.unit.TopicGroupFragment"
        android:label="Nhóm chủ đề AI"
        tools:layout="@layout/fragment_topic_groups">
        <argument
            android:name="unit_id"
            app:argType="long" />
        <argument
            android:name="unit_title"
            app:argType="string" />
    </fragment>

    <fragment
        android:id="@+id/quizSetupFragment"
        android:name="com.lumina.app.ui.quiz.QuizSetupFragment"
        android:label="Quiz Setup"
        tools:layout="@layout/fragment_quiz_setup">
        <argument
            android:name="lesson_id"
            android:defaultValue="-1L"
            app:argType="long" />
        <argument
            android:name="topic_group_id"
            android:defaultValue="-1L"
            app:argType="long" />
        <argument
            android:name="lesson_name"
            app:argType="string"
            android:defaultValue="Lesson" />
        <argument
            android:name="unit_name"
            app:argType="string"
            android:defaultValue="Unit" />
    </fragment>

    <fragment
        android:id="@+id/quizFragment"
        android:name="com.lumina.app.ui.quiz.QuizFragment"
        android:label="Quiz"
        tools:layout="@layout/fragment_quiz">
        <argument
            android:name="lesson_id"
            android:defaultValue="-1L"
            app:argType="long" />
        <argument
            android:name="topic_group_id"
            android:defaultValue="-1L"
            app:argType="long" />
        <argument
            android:name="question_count"
            app:argType="integer"
            android:defaultValue="10" />
        <argument
            android:name="use_multiple_choice"
            app:argType="boolean"
            android:defaultValue="true" />
        <argument
            android:name="use_fill_blank"
            app:argType="boolean"
            android:defaultValue="true" />
        <argument
            android:name="mode"
            app:argType="string"
            android:defaultValue="Practice" />
    </fragment>

    <fragment
        android:id="@+id/quizResultFragment"
        android:name="com.lumina.app.ui.quiz.QuizResultFragment"
        android:label="Quiz Result"
        tools:layout="@layout/fragment_quiz_result" />

</navigation>
