<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFF">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/header"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:paddingHorizontal="16dp"
        app:layout_constraintTop_toTopOf="parent">

        <ImageButton
            android:id="@+id/btnExit"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Thoát"
            android:src="@drawable/ic_close"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#1E293B" />

        <TextView
            android:id="@+id/tvQuestionCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Câu 3 / 20"
            android:textColor="#1E293B"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btnSettings"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Cài đặt"
            android:src="@drawable/ic_settings"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="#1E293B" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/quizProgressBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginHorizontal="24dp"
        app:indicatorColor="#0056D2"
        app:layout_constraintEnd_toStartOf="@id/layoutTimer"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/header"
        app:trackColor="#E2E8F0"
        app:trackCornerRadius="4dp"
        app:trackThickness="8dp" />

    <LinearLayout
        android:id="@+id/layoutTimer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginEnd="24dp"
        android:background="@drawable/bg_badge_gray"
        android:backgroundTint="#EEF2FF"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingHorizontal="12dp"
        android:paddingVertical="6dp"
        app:layout_constraintBottom_toBottomOf="@id/quizProgressBar"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="@id/quizProgressBar">

        <ImageView
            android:layout_width="16dp"
            android:layout_height="16dp"
            android:src="@drawable/ic_calendar"
            app:tint="#4338CA" />

        <TextView
            android:id="@+id/tvTimer"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="6dp"
            android:text="28s"
            android:textColor="#4338CA"
            android:textSize="14sp"
            android:textStyle="bold" />
    </LinearLayout>

    <!-- Multiple Choice Layout -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutMultipleChoice"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="visible"
        app:layout_constraintBottom_toTopOf="@id/btnNext"
        app:layout_constraintTop_toBottomOf="@id/quizProgressBar">

        <View
            android:id="@+id/viewIconBg"
            android:layout_width="100dp"
            android:layout_height="100dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_icon_circle_blue_light"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:id="@+id/ivQuestionIcon"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:src="@drawable/ic_plane"
            app:layout_constraintBottom_toBottomOf="@id/viewIconBg"
            app:layout_constraintEnd_toEndOf="@id/viewIconBg"
            app:layout_constraintStart_toStartOf="@id/viewIconBg"
            app:layout_constraintTop_toTopOf="@id/viewIconBg"
            app:tint="#0056D2" />

        <TextView
            android:id="@+id/tvQuestionWord"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="24dp"
            android:text="departure"
            android:textColor="#1E293B"
            android:textSize="32sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/viewIconBg" />

        <LinearLayout
            android:id="@+id/layoutIpaAudio"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="8dp"
            android:background="@drawable/bg_badge_gray"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvQuestionWord">

            <TextView
                android:id="@+id/tvQuestionIpa"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="/dɪˈpɑːtʃə/"
                android:textColor="#64748B"
                android:textSize="16sp" />

            <ImageView
                android:id="@+id/btnQuestionAudio"
                android:layout_width="20dp"
                android:layout_height="20dp"
                android:layout_marginStart="12dp"
                android:src="@drawable/ic_volume_up"
                app:tint="#0056D2" />
        </LinearLayout>

        <LinearLayout
            android:id="@+id/layoutMcOptions"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="32dp"
            android:orientation="vertical"
            android:paddingHorizontal="24dp"
            app:layout_constraintTop_toBottomOf="@id/layoutIpaAudio">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOption1"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:gravity="left|center_vertical"
                android:paddingStart="24dp"
                android:text="sự trở về"
                android:textAllCaps="false"
                android:textColor="#1E293B"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_sparkle"
                app:iconGravity="textStart"
                app:iconPadding="16dp"
                app:strokeColor="#E2E8F0" />

            <!-- Buttons for B, C, D follow similar pattern -->
            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOption2"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:gravity="left|center_vertical"
                android:paddingStart="24dp"
                android:text="sự khởi hành"
                android:textAllCaps="false"
                android:textColor="#1E293B"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_sparkle"
                app:iconGravity="textStart"
                app:iconPadding="16dp"
                app:strokeColor="#E2E8F0" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOption3"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:layout_marginBottom="12dp"
                android:gravity="left|center_vertical"
                android:paddingStart="24dp"
                android:text="cổng kiểm tra"
                android:textAllCaps="false"
                android:textColor="#1E293B"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_sparkle"
                app:iconGravity="textStart"
                app:iconPadding="16dp"
                app:strokeColor="#E2E8F0" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btnOption4"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="64dp"
                android:gravity="left|center_vertical"
                android:paddingStart="24dp"
                android:text="hành lý"
                android:textAllCaps="false"
                android:textColor="#1E293B"
                android:textSize="16sp"
                app:cornerRadius="16dp"
                app:icon="@drawable/ic_sparkle"
                app:iconGravity="textStart"
                app:iconPadding="16dp"
                app:strokeColor="#E2E8F0" />

        </LinearLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Fill in the Blank Layout -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/layoutFillBlank"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:visibility="gone"
        app:layout_constraintBottom_toTopOf="@id/btnNext"
        app:layout_constraintTop_toBottomOf="@id/quizProgressBar">

        <TextView
            android:id="@+id/tvFillBlankLabel"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="24dp"
            android:text="FILL IN THE BLANK"
            android:textColor="#3B82F6"
            android:textSize="12sp"
            android:textStyle="bold"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <TextView
            android:id="@+id/tvSentence"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginTop="12dp"
            android:lineSpacingExtra="8dp"
            android:text="The _______ gate is on the left side of the terminal."
            android:textColor="#1E293B"
            android:textSize="22sp"
            android:textStyle="bold"
            app:layout_constraintTop_toBottomOf="@id/tvFillBlankLabel" />

        <LinearLayout
            android:id="@+id/layoutHint"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:layout_marginTop="32dp"
            android:background="@drawable/bg_streak_badge"
            android:backgroundTint="#A3E635"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="16dp"
            android:paddingVertical="8dp"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toBottomOf="@id/tvSentence">

            <ImageView
                android:layout_width="16dp"
                android:layout_height="16dp"
                android:src="@drawable/ic_brain"
                app:tint="#1E293B" />

            <TextView
                android:id="@+id/tvHintText"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginStart="8dp"
                android:text="Gợi ý: d_______"
                android:textColor="#1E293B"
                android:textSize="15sp"
                android:textStyle="bold" />
        </LinearLayout>

        <com.google.android.material.textfield.TextInputLayout
            android:id="@+id/tilAnswerInput"
            style="@style/Widget.MaterialComponents.TextInputLayout.OutlinedBox"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginHorizontal="24dp"
            android:layout_marginBottom="32dp"
            android:hint="Nhập từ tiếng Anh"
            app:boxCornerRadiusBottomEnd="16dp"
            app:boxCornerRadiusBottomStart="16dp"
            app:boxCornerRadiusTopEnd="16dp"
            app:boxCornerRadiusTopStart="16dp"
            app:layout_constraintBottom_toBottomOf="parent">

            <com.google.android.material.textfield.TextInputEditText
                android:id="@+id/etAnswerInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:inputType="text" />
        </com.google.android.material.textfield.TextInputLayout>

    </androidx.constraintlayout.widget.ConstraintLayout>

    <!-- Footer Button -->
    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnNext"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_margin="16dp"
        android:text="Tiếp tục"
        android:textAllCaps="false"
        android:textSize="16sp"
        android:textStyle="bold"
        app:cornerRadius="28dp"
        app:layout_constraintBottom_toBottomOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
