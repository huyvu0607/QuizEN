<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8FAFF">

    <ImageButton
        android:id="@+id/btnBack"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginStart="8dp"
        android:layout_marginTop="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Back"
        android:src="@drawable/ic_arrow_back"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#1A1C1E" />

    <TextView
        android:id="@+id/tvUnitTitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center"
        android:text="Unit 1: Airport"
        android:textColor="#0056D2"
        android:textSize="18sp"
        android:fontFamily="sans-serif-medium"
        app:layout_constraintBottom_toBottomOf="@id/btnBack"
        app:layout_constraintEnd_toStartOf="@id/btnSettings"
        app:layout_constraintStart_toEndOf="@id/btnBack"
        app:layout_constraintTop_toTopOf="@id/btnBack" />

    <ImageButton
        android:id="@+id/btnSettings"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="8dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Settings"
        android:src="@drawable/ic_settings"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:tint="#1A1C1E" />

    <com.google.android.material.progressindicator.LinearProgressIndicator
        android:id="@+id/progressBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="64dp"
        android:layout_marginTop="8dp"
        android:layout_marginEnd="64dp"
        app:indicatorColor="#A3E635"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/tvUnitTitle"
        app:trackColor="#E2E8F0"
        app:trackCornerRadius="4dp"
        app:trackThickness="6dp"
        android:progress="33"/>

    <TextView
        android:id="@+id/tvProgress"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="4dp"
        android:text="5 / 15 từ"
        android:textColor="#64748B"
        android:textSize="12sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/progressBar" />

    <androidx.viewpager2.widget.ViewPager2
        android:id="@+id/viewPager"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_marginTop="16dp"
        android:layout_marginBottom="16dp"
        android:clipChildren="false"
        android:clipToPadding="false"
        app:layout_constraintBottom_toTopOf="@id/layoutSrsButtons"
        app:layout_constraintTop_toBottomOf="@id/tvProgress" />

    <LinearLayout
        android:id="@+id/layoutSrsButtons"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingVertical="20dp"
        android:visibility="invisible"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnAgain"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Chưa nhớ"
            android:textColor="@android:color/white"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="#FF5C5C"
            app:cornerRadius="12dp"
            app:elevation="2dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnHard"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:layout_marginEnd="6dp"
            android:text="Mang máng"
            android:textColor="@android:color/white"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="#FFB347"
            app:cornerRadius="12dp"
            app:elevation="2dp" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnGood"
            android:layout_width="0dp"
            android:layout_height="52dp"
            android:layout_weight="1"
            android:text="Nhớ tốt"
            android:textColor="@android:color/white"
            android:textAllCaps="false"
            android:textSize="12sp"
            android:textStyle="bold"
            android:padding="0dp"
            android:insetTop="0dp"
            android:insetBottom="0dp"
            app:backgroundTint="#4ADE80"
            app:cornerRadius="12dp"
            app:elevation="2dp" />

    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
